          ]
        },
        {
          "name": "Rampart",
          "type": "Abilities",
          "lines": [
            {
              "name": "Description",
              "value": "Once per battle, at the start of any phase, this model can use this ability. If it does, until the end of the phase, this model has a 2+ invulnerable save."
            }
          ]
        },
        {
          "name": "Leader",
          "type": "Abilities",
          "lines": [
            {
              "name": "Description",
              "value": "This model can be attached to the following units:\n\n■ Relic Terminator Squad\n■ Terminator Assault Squad\n■ Terminator Squad"
            }
          ]
        },
        {
          "name": "Inspiring Commander",
          "type": "Abilities",
          "lines": [
            {
              "name": "Description",
              "value": "‘If you include this model in your army, until the end of the battle, non-Character models in Terminator Assault Squad and Terminator Squad units from your army have an Objective Control characteristic of 2 while they are not Battle-shocked."
            }
          ]
        }
