          "type": "Abilities",
          "lines": [
            {
              "name": "Description",
              "value": "This model can be attached to the following units:\n\n■ Company Heroes\n■ Bladeguard Veteran Squad\n■ Sternguard Veteran Squad\n■ Tactical Squad"
            }
          ]
        },
