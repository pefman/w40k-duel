          "name": "Inspiring Commander",
          "type": "Abilities",
          "lines": [
            {
              "name": "Description",
              "value": "If you include this model in your army, until the end of the battle, non-Character models in Sternguard\nVeteran Squad units from your army have an Objective Control characteristic of 2 while they are not Battle-shocked."
            }
          ]
        }
