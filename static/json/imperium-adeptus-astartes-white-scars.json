          ]
        },
        {
          "name": "Inspiring Commander",
          "type": "Abilities",
          "lines": [
            {
              "name": "Description",
              "value": "If you include this model in your army, until the end of the battle, non-Character models in Outrider Squad units from your army have an Objective Control characteristic of 3 while they are not Battle-shocked."
            }
          ]
